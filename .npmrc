# Do not run package lifecycle scripts (preinstall/install/postinstall/prepare)
# on install. This neutralizes the most common supply-chain attack vector so
# the intentionally-vulnerable dependencies in this repo stay inert.
ignore-scripts=true

# Refuse to install any package version published less than 7 days ago
# (10080 minutes). This standardizes the "minimum release age" rule so freshly
# published, potentially compromised or yanked supply-chain releases are skipped
# automatically. Requires pnpm v10.16+. Value is in minutes.
minimum-release-age=10080
